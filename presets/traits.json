    { "id": "height", "label": "Height", "type": "text", "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "build", "label": "Build", "type": "text", "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "complexion", "label": "Complexion", "type": "text", "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "hair", "label": "Hair", "type": "text", "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "eyes", "label": "Eyes", "type": "text", "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "distinguishing_features", "label": "Distinguishing", "type": "text", "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } }
  ]
}
