{
  "id": "state", "label": "State", "icon": "fa-face-smile",
  "source": "preset:state",
  "appliesToRoles": ["protagonist","npc"],
  "autoUpdate": true,
  "injection": {
    "enabled": true,
    "trigger": "always",
    "position": "in-chat",
    "depth": 1,
    "template": "<injection>\n**{{subject}}:**\n{{fields}}\n</injection>"
  },
  "fields": [
    { "id": "mood", "label": "Mood", "type": "enum",
      "options": ["neutral","happy","sad","angry","curious","afraid","aroused","smug","wistful","confident"],
      "default": "neutral", "describable": true, "descriptionScope": "per-subject",
      "inclusion": { "rule": "always" },
      "injection": { "enabled": true } },
    { "id": "temporary_status_effects", "label": "Temporary status effects", "type": "list", "default": [], "describable": true, "descriptionScope": "per-subject",
      "inclusion": { "rule": "active", "activeWindow": 5 },
      "injection": { "enabled": true } },
    { "id": "permanent_conditions", "label": "Permanent conditions", "type": "list", "default": [], "describable": true, "descriptionScope": "per-subject",
      "inclusion": { "rule": "always" },
      "injection": { "enabled": true } }
  ]
}
