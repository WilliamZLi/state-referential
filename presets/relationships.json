{
  "id": "relationships", "label": "Relationships", "icon": "fa-heart",
  "source": "preset:relationships",
  "appliesToRoles": ["npc"],
  "autoUpdate": true,
  "injection": {
    "enabled": true,
    "trigger": "tag",
    "tags": ["social","intimate"],
    "position": "in-chat",
    "depth": 3,
    "template": "**{{subject}} ↔ protagonist:**\n{{fields}}"
  },
  "fields": [
    { "id": "dynamic_with_protagonist", "label": "Dynamic with protagonist", "type": "prose", "default": "", "describable": true, "injection": { "enabled": true } },
    { "id": "last_interaction_summary", "label": "Last interaction", "type": "text", "default": "", "describable": false,
      "inclusion": { "rule": "active", "activeWindow": 10 },
      "injection": { "enabled": false } }
  ]
}
