{
  "id": "stats", "label": "Stats", "icon": "fa-heart-pulse",
  "source": "preset:stats",
  "appliesToRoles": ["protagonist","npc"],
  "autoUpdate": true,
  "injection": {
    "enabled": true,
    "trigger": "always",
    "position": "in-chat",
    "depth": 2,
    "template": "<injection>\n**{{subject}} stats:**\n{{fields}}\n</injection>"
  },
  "fields": [
    { "id": "health", "label": "Health", "type": "number", "min": 0, "max": 100, "default": 100, "allowDelta": true, "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "stamina", "label": "Stamina", "type": "number", "min": 0, "max": 100, "default": 100, "allowDelta": true, "describable": false, "inclusion": { "rule": "always" }, "injection": { "enabled": true } },
    { "id": "arousal", "label": "Arousal", "type": "number", "min": 0, "max": 100, "default": 0, "allowDelta": true, "describable": false, "inclusion": { "rule": "tag", "tags": ["intimate"] }, "injection": { "enabled": true } },
    { "id": "sensitivity_neck", "label": "Sensitivity (neck)", "type": "number", "min": 0, "max": 100, "default": 50, "allowDelta": true, "describable": false, "inclusion": { "rule": "tag", "tags": ["intimate"] }, "injection": { "enabled": false } },
    { "id": "sensitivity_ears", "label": "Sensitivity (ears)", "type": "number", "min": 0, "max": 100, "default": 50, "allowDelta": true, "describable": false, "inclusion": { "rule": "tag", "tags": ["intimate"] }, "injection": { "enabled": false } }
  ]
}
